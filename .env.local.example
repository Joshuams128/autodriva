# MongoDB Atlas connection string
MONGODB_URI=

# NextAuth — REQUIRED. Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Set to your deployed URL in production (e.g. https://autodriva.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Admin login (single admin user)
# Generate password hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
